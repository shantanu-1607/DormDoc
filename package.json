{
  "name": "dormdoc",
  "version": "1.0.0",
  "description": "DormDoc — College Dispensary Management System for BIT Mesra",
  "main": "src/server/server.js",
  "scripts": {
    "build": "cd src/client && npm run build",
    "start": "node src/server/server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon src/server/server.js",
    "client": "cd src/client && npm start",
    "seed": "node scripts/seed.js",
    "install-client": "cd src/client && npm install",
    "heroku-postbuild": "npm run install-client && npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "college",
    "dispensary",
    "medical",
    "management",
    "system",
    "bit-mesra",
    "dormdoc"
  ],
  "author": "mightbeanshuu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mightbeanshuu/DormDoc.git"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "axios": "^1.16.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.3.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.4",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.0.1",
    "supabase": "^2.101.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "src/client/src/**/*.{js,jsx}": [
      "npm run lint --prefix src/client"
    ]
  }
}
